{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bijay-algo/solvrays-experience/week1/schemas/input_schema.json",
  "title": "DataValidatorInput",
  "description": "Input contract for the Week 1 data_validator handle() function.",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "description": "Email address to validate.",
      "examples": ["user@example.com", "bijay.algo+tag@gmail.com"]
    },
    "phone": {
      "type": "string",
      "description": "Phone number to validate. Accepts international format (+977-...) or local digits.",
      "examples": ["+977-9801234567", "9841000111", "+1 (415) 555-0172"]
    }
  },
  "required": ["email", "phone"],
  "additionalProperties": false
}
